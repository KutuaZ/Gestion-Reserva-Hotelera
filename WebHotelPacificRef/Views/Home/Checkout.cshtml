@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hotel Pacific Reef - Reserva</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        .top-bar { background-color: #1a36c4; }
        .nav-bar-light { background-color: #8fa5ff; }
        .tarjeta-box { background-color: #1a36c4; border-radius: 10px; }
    </style>
</head>
<body class="bg-light">

    <!-- Header Idéntico -->
    <header>
        <div class="top-bar d-flex justify-content-between align-items-center px-4 py-2">
            <div style="width: 150px;"></div>
            <img src="~/logo.png" alt="Logo" style="height: 80px;" />
            <button class="btn btn-light fw-bold">Iniciar Sesion</button>
        </div>
        <div class="nav-bar-light border-bottom border-dark py-2">
            <ul class="nav justify-content-center fw-bold text-dark fs-5 gap-5">
                <li><a href="/Home/Index" class="text-dark text-decoration-none">Inicio</a></li>
                <li><a href="#" class="text-dark text-decoration-none">Habitaciones</a></li>
                <li><a href="#" class="text-dark text-decoration-none">Nosotros</a></li>
                <li><a href="#" class="text-dark text-decoration-none">Contacto</a></li>
            </ul>
        </div>
    </header>

    <div class="container-fluid mt-4">
        <div class="row bg-white border shadow-sm mx-2" style="min-height: 70vh;">
            
            <!-- Columna Izquierda: Resumen (Simulado) -->
            <div class="col-md-6 border-end p-5 text-center">
                <h3 class="fw-bold mb-5">Resumen De Tu Estadia</h3>
                <p class="fs-5 mb-4">Habitacion: Matrimonial Vista Mar.</p>
                <p class="fs-5 mb-5">Fechas: 10/05/2026 - 15/05/2026.</p>
                <p class="fs-4 mt-5">Total a pagar: <span class="fw-bold">$425.000.</span></p>
            </div>

            <!-- Columna Derecha: Formulario Real -->
            <div class="col-md-6 p-5">
                <h3 class="fw-bold mb-4 text-center">1. Datos Del Pasajero</h3>
                
                <!-- El Formulario apunta al método ProcesarReserva -->
                <form asp-controller="Home" asp-action="ProcesarReserva" method="post">
                    
                    <div class="mb-3">
                        <label class="fw-bold">RUT</label>
                        <input type="text" name="Rut" class="form-control" placeholder="Ej: 12.345.678-9" required />
                    </div>

                    <!-- Nombre y Apellido en la misma fila -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-bold">NOMBRE</label>
                            <input type="text" name="Nombre" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="fw-bold">APELLIDO</label>
                            <input type="text" name="Apellido" class="form-control" required />
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label class="fw-bold">CORREO ELECTRÓNICO</label>
                        <input type="email" name="Correo" class="form-control" placeholder="ejemplo@correo.com" required />
                    </div>

                    <div class="mb-4">
                        <label class="fw-bold">TELÉFONO</label>
                        <input type="text" name="Telefono" class="form-control" placeholder="+56 9 1234 5678" required />
                    </div>

                    <!-- Caja de Tarjeta (Simulada, no se envía a BD) -->
                    <div class="tarjeta-box p-4 text-white mb-4 shadow">
                        <input type="text" class="form-control mb-3" placeholder="Numero De Tarjeta" required>
                        <div class="d-flex gap-3">
                            <input type="text" class="form-control" placeholder="Fecha De Exp" required>
                            <input type="text" class="form-control" placeholder="CVV" required>
                        </div>
                    </div>

                    <div class="text-end">
                        <button type="submit" class="btn btn-success fw-bold px-4 py-3" style="background-color: #39d936;">FINALIZAR RESERVA Y PAGAR</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

</body>
</html>